# Copy this file to `.env` (which is gitignored and never leaves your machine) and fill in the values.

# Notesnook Inbox API key.
# Get it in Notesnook: Settings -> Inbox -> Enable Inbox API -> create an API key -> paste here.
NOTESNOOK_INBOX_API_KEY=

# Folder where the iOS Shortcut drops new recordings, mirrored to this PC by iCloud for Windows.
# NOTE: Explorer shows this as ...\iCloudDrive\Shortcuts\VoiceInbox, but on disk the Shortcuts
# app's folder is named after its container id (iCloud~is~workflow~my~workflows).
VOICE_INBOX_DIR=C:\Users\Douglas\iCloudDrive\iCloud~is~workflow~my~workflows\VoiceInbox
